# 当前运行环境名称
VITE_APP_ENV=staging

# 项目标题
VITE_APP_TITLE=Vue3 Admin Template Staging

# 预发环境默认关闭本地 mock，直接连真实后端
VITE_USE_MOCK=false

# 预发环境接口基础地址
# 这里先用示例地址占位，后续接真实接口时再替换。
VITE_API_BASE_URL=https://staging-api.example.com

# 预发环境默认也生成 gzip / brotli 预压缩资源
# 这样联调静态资源分发策略时，可以更接近正式环境表现
VITE_BUILD_COMPRESS=true

# 只压缩达到阈值的文本资源，避免生成过多低收益压缩文件
VITE_BUILD_COMPRESS_THRESHOLD=10240
