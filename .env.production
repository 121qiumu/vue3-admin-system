# 当前运行环境名称
VITE_APP_ENV=production

# 项目标题
VITE_APP_TITLE=Vue3 Admin Template

# 生产环境必须关闭本地 mock
VITE_USE_MOCK=false

# 生产环境接口基础地址
# 这里先用示例地址占位，后续上线前请替换为真实地址。
VITE_API_BASE_URL=https://api.example.com

# 生产构建是否生成 gzip / brotli 预压缩资源
# true：生成 .gz 和 .br 文件
# false：关闭预压缩，方便快速回退
VITE_BUILD_COMPRESS=true

# 只压缩达到阈值的文本资源，避免生成过多低收益压缩文件
VITE_BUILD_COMPRESS_THRESHOLD=10240
