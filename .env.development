# 当前运行环境名称
VITE_APP_ENV=development

# 项目标题
VITE_APP_TITLE=Vue3 Admin Template Dev

# 开发环境是否启用本地 mock
# true：优先走 src/mock 中的本地数据
# false：直接走真实后端接口
VITE_USE_MOCK=true

# 开发服务器主机地址
# 0.0.0.0 表示允许局域网访问
VITE_DEV_HOST=0.0.0.0

# 开发服务器端口
VITE_DEV_PORT=5173

# 启动项目时是否自动打开浏览器
VITE_DEV_OPEN=false

# 前端请求接口时统一使用的前缀
VITE_API_PREFIX=/api

# 开发代理目标地址
# 当前先留空，等接入真实后端或独立 mock 服务时再填写
VITE_API_PROXY_TARGET=

# 开发环境接口基础地址
VITE_API_BASE_URL=/api